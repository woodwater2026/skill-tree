{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waterwoods.ai/skill-tree/schema/skill.schema.json",
  "title": "Skill Tree Skill Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "slug",
    "primary_category",
    "summary",
    "source",
    "security",
    "audit",
    "discovery",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "primary_category": {
      "type": "string",
      "enum": [
        "development",
        "research",
        "productivity",
        "communication",
        "data-analysis",
        "security-compliance",
        "agent-operations",
        "system-environment",
        "creativity"
      ]
    },
    "secondary_categories": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "maxItems": 10
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 50 },
      "uniqueItems": true,
      "maxItems": 20
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "description": {
      "type": "string",
      "maxLength": 4000
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_url", "platform"],
      "properties": {
        "repo_url": { "type": "string", "format": "uri" },
        "platform": { "type": "string", "enum": ["github", "gitlab", "other"] },
        "owner": { "type": "string" },
        "repo": { "type": "string" },
        "default_branch": { "type": "string" },
        "license": { "type": "string" },
        "stars": { "type": "integer", "minimum": 0 },
        "forks": { "type": "integer", "minimum": 0 }
      }
    },
    "maintainer": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "handle": { "type": "string" },
        "url": { "type": "string", "format": "uri" }
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agents": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "os": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "languages": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "maxItems": 20
    },
    "security": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_level", "summary"],
      "properties": {
        "risk_level": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "summary": {
          "type": "array",
          "items": { "type": "string", "maxLength": 240 },
          "minItems": 1,
          "maxItems": 5
        },
        "network_access": { "type": "boolean" },
        "file_write": { "type": "boolean" },
        "shell_execution": { "type": "boolean" },
        "browser_control": { "type": "boolean" },
        "credentials_access": { "type": "boolean" },
        "sensitive_paths": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "findings_count"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "draft", "reviewed", "verified"]
        },
        "findings_count": { "type": "integer", "minimum": 0 },
        "last_audited_at": { "type": "string", "format": "date-time" },
        "auditor": { "type": "string" },
        "recommendation": {
          "type": "string",
          "enum": ["use", "review", "avoid"]
        },
        "findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "severity", "title"],
            "properties": {
              "id": { "type": "string" },
              "severity": {
                "type": "string",
                "enum": ["info", "low", "medium", "high", "critical"]
              },
              "title": { "type": "string", "maxLength": 200 },
              "description": { "type": "string", "maxLength": 4000 },
              "evidence": { "type": "string", "maxLength": 4000 },
              "path": { "type": "string" },
              "line": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },
    "discovery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["discovered_from"],
      "properties": {
        "discovered_from": { "type": "string" },
        "catalog_version": { "type": "string" },
        "featured": { "type": "boolean" },
        "popularity_score": { "type": "number", "minimum": 0 },
        "quality_score": { "type": "number", "minimum": 0 },
        "security_score": { "type": "number", "minimum": 0 }
      }
    },
    "examples": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "description"],
        "properties": {
          "title": { "type": "string" },
          "description": { "type": "string" },
          "input": { "type": "string" },
          "output": { "type": "string" }
        }
      },
      "maxItems": 5
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
